# ImmortalWrt rockchip/armv8 — minimal target-only config.
#
# Covers most popular ARM64 single-board routers/SBCs:
#   - FriendlyARM NanoPi R2S / R4S / R5S / R6S
#   - Orange Pi 5 / 5 Plus / R1 Plus
#   - Radxa Rock 5B
#   - and other RK3328/3399/3568/3588 boards
#
# Note: Phicomm N1 (Amlogic S905D) is NOT in this target. N1 users
# typically use the third-party `ophub` Amlogic branch.

CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_CCACHE=y
