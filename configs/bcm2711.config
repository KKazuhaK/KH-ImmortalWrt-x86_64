# ImmortalWrt bcm27xx/bcm2711 — Raspberry Pi 4 / Pi 400 / CM4.
#
# Other Pi models need a different subtarget — copy this file and change
# the subtarget line:
#   bcm2708  — Pi 1, Zero, Zero W (ARMv6)
#   bcm2709  — Pi 2 (ARMv7)
#   bcm2710  — Pi 3, Zero 2 W   (ARMv8, 32-bit userland)
#   bcm2711  — Pi 4, Pi 400, CM4 (ARMv8, 64-bit)         ← this file
#   bcm2712  — Pi 5             (ARMv8, 64-bit)

CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2711=y
CONFIG_CCACHE=y
