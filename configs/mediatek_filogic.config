# ImmortalWrt mediatek/filogic — MediaTek MT7981 / MT7986 / MT7988 SoCs.
# ARMv8-A 64-bit, used in current-gen Wi-Fi 6/7 routers.
#
# Notable devices:
#   - Xiaomi AX3000T, Mi Router AX3000
#   - Redmi BE6500, AX6000
#   - TP-Link Archer BE220 / BE3600 / AX23
#   - Mercusys MR70X
#   - GL.iNet Flint 2 (GL-MT6000)
#   - iKuai DR4300

CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_CCACHE=y
