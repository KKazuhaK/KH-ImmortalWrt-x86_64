# ImmortalWrt x86_64 — minimal target-only config.
# `make defconfig` will fill in ImmortalWrt's default packages for this target,
# producing an official-style x86_64 generic image. Use this for the first
# end-to-end pipeline test; replace with `make menuconfig` output later.

CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# Make rootfs partition large enough for PassWall + OpenClash + 4 proxy
# cores + Tailscale + ZeroTier + cloudflared + theme + KMS — the default
# 160 MB blew up the ext4 image generation with "failed to allocate ...
# out of space?" on run 25645558352. 1 GB leaves comfortable headroom
# and matches what most software-router users want anyway. squashfs is
# variable-size and unaffected; this only sets the partition size used
# by `*-combined*.img.gz`.
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
CONFIG_TARGET_KERNEL_PARTSIZE=32

# Enable ccache so the workflow can cache compiled object files
# across runs (drives the 2h → ~50min speedup on subsequent builds).
CONFIG_CCACHE=y

# === PassWall integration (third-party feed: kenzok8/small-package) ===

# Both PassWall versions — install side-by-side, pick whichever in LuCI.
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y

# Proxy cores — PassWall is UI only; you need at least one of these to
# actually proxy traffic. All four chosen for maximum protocol coverage
# (covers TUIC, AnyTLS, WireGuard-as-outbound which only sing-box does).
#
# Important: sing-box MUST come from the small-package feed (1.13.11+),
# not from ImmortalWrt's own packages feed (which still ships 1.12.25 — a
# version with a broken sagernet/tailscale fork that fails `go build`).
# scripts/diy-part2.sh force-installs sing-box from the small8 feed to
# avoid the default first-wins feed-install behaviour picking the broken
# packages-feed copy.
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_hysteria=y
CONFIG_PACKAGE_shadowsocks-rust-sslocal=y

# === OpenClash (Clash-based proxy with rule-set / GeoIP support) ===
# Bundles Mihomo / Clash.Meta cores at runtime — you only need the LuCI app
# here; the core binary is downloaded on first launch via OpenClash itself.
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y

# === Argon theme — modern LuCI look (config app lets you change bg / opacity) ===
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# === KMS server (vlmcsd) — activate Windows / Office against this router ===
CONFIG_PACKAGE_vlmcsd=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y

# === Cloudflare Tunnel / Zero Trust client ===
# cloudflared is the daemon; configure via /etc/cloudflared/config.yml
# or `cloudflared tunnel login` — no LuCI front-end in the default feeds.
CONFIG_PACKAGE_cloudflared=y

# === Tailscale — zero-config mesh VPN (recommended for most users) ===
# luci-app-tailscale is re-enabled; scripts/diy-part2.sh strips the
# small-package version's duplicate /etc/config/tailscale and
# /etc/init.d/tailscale before compile, so only the LuCI UI ships and
# the native `tailscale` package owns config/init.
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=y

# === ZeroTier — alternative mesh VPN, more knobs / self-hostable controller ===
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y

# === SNMP daemon — for Prometheus / Zabbix / LibreNMS monitoring ===
# scripts/diy-part2.sh strips small-package luci-app-snmpd's duplicate
# init/config files so the LuCI front-end can coexist with the upstream
# snmpd daemon package.
CONFIG_PACKAGE_snmpd=y
CONFIG_PACKAGE_luci-app-snmpd=y
CONFIG_PACKAGE_luci-i18n-snmpd-zh-cn=y
