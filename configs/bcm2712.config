# ImmortalWrt bcm27xx/bcm2712 — Raspberry Pi 5.
# Broadcom BCM2712 (Cortex-A76 ×4 @ 2.4 GHz), ARMv8-A 64-bit.
#
# Note: Pi 5 support in OpenWrt 24.10 is recent; some peripherals
# (Wi-Fi/BT chip, PCIe quirks) may need extra kernel modules.

CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2712=y
CONFIG_CCACHE=y
